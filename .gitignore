# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# agent memory — not part of the committed codebase
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor native project (regenerated by CI / cap add ios)
/ios
/android

# Store screenshots (generated locally, not tracked)
play-store-assets/

# Local markdown docs (guides, prep sheets) — keep out of the repo going forward.
# Already-tracked .md files remain tracked; this only ignores new ones.
*.md

# Full-size source masters. Keep these locally; the repo carries only the
# optimized derivatives under public/images/ (a single PNG master outweighs
# every poster we ship). The already-tracked golf*.jpg are unaffected.
content/source-images/*.png
